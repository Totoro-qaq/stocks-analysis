# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=us_stock_mvp

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Observability
OTEL_ENABLED=true
OTEL_SERVICE_NAME=stocks-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# DeepSeek / OpenAI-compatible report generation
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=low
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_STREAMING=true

# Dify workflow integration
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_REPORT_API_KEY=
DIFY_RULES_API_KEY=
DIFY_USER=stocks-analysis-local
DIFY_RESPONSE_MODE=streaming
DIFY_TIMEOUT=120
